# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# CLI only — for `npm run db:push:remote` / supabase db push (never commit)
# Dashboard → Project Settings → Database → Database password
# SUPABASE_DB_PASSWORD=

# LINE
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
NEXT_PUBLIC_LINE_LIFF_ID=
# LIFF แยกสำหรับ inbound scan (endpoint /liff/inbound-scan + Scan QR) — รัน scripts/register-liff-inbound-scan.mjs
NEXT_PUBLIC_LINE_LIFF_INBOUND_SCAN_ID=

# App
NEXT_PUBLIC_BASE_URL=

# E2E remote (optional) — run: npm run e2e:bootstrap-remote
# Creates gitignored .env.e2e.local; then: npm run test:e2e:p3:remote

# Optional
HR_LINE_GROUP_ID=
# false (default) = ไม่ตอบข้อความแชทจากผู้ใช้ — ใช้ Rich Menu / postback / แชร์ตำแหน่งเท่านั้น
# คำสั่ง /stock / /inbound ทำงานแยก ไม่ต้องเปิด LINE_USER_CHAT_ENABLED
LINE_USER_CHAT_ENABLED=false
# true = เปิดคำสั่ง /stock ใน LINE (HR เปิดเมื่อพร้อมให้พนักงานดูสต็อก)
LINE_STOCK_COMMAND_ENABLED=true
WORK_START_HOUR=9
WORK_START_MINUTE=0

# LINE Login channel (T04 — แยกจาก Messaging API channel)
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# Odoo ERP Integration (Payroll)
# Leave empty if not using Odoo integration
ODOO_URL=http://localhost:8069
ODOO_DB=hr_payroll
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

