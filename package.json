  "scripts": {
    "dev": "next dev -p 3001 --experimental-https --experimental-https-key certificates/localhost-key.pem --experimental-https-cert certificates/localhost.pem",
    "dev:http": "next dev -p 3001",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/lib/payroll/*.test.ts src/lib/attendance/*.test.ts src/lib/approval/*.test.ts src/lib/employees/*.test.ts src/lib/inventory/*.test.ts",
    "seed:admin": "node scripts/seed-admin.mjs",
