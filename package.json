    "test:e2e:remote": "E2E_REMOTE=1 node scripts/e2e/run-all.mjs",
    "test:e2e:p3": "node scripts/e2e/run-all-p3.mjs",
    "test:e2e:p3:remote": "E2E_REMOTE=1 node scripts/e2e/run-all-p3.mjs",
    "test:e2e:p4": "node scripts/e2e/run-all-p4.mjs",
    "test:e2e:p4:remote": "E2E_REMOTE=1 node scripts/e2e/run-all-p4.mjs",
    "test:e2e:p5": "node scripts/e2e/run-all-p5.mjs",
    "test:e2e:p5:remote": "E2E_REMOTE=1 node scripts/e2e/run-all-p5.mjs",
    "e2e:bootstrap-remote": "node scripts/e2e/bootstrap-remote-env.mjs",
    "db:push:remote": "bash scripts/db-push-linked.sh",
    "line:greeting-setup": "node scripts/line-oa-greeting-setup.mjs"
