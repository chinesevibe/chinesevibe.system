    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/qrcode": "^1.5.6",
    "@vercel/speed-insights": "^2.0.0",
    "@zxing/browser": "0.2.0",
    "@zxing/library": "0.22.0",
    "bwip-js": "^4.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
